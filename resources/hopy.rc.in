// hopy.exe Win32 resources: application icon + version info.
// Generated from this template by CMake (configure_file, @ONLY) so the version
// tracks project(VERSION ...). Do not edit the generated copy under the build dir.
#pragma code_page(65001)

// Lowest-numbered icon resource becomes the executable's icon (Explorer/taskbar).
1 ICON "@HOPY_RC_ICON@"

1 VERSIONINFO
 FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         0x40004L
 FILETYPE       0x1L
 FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Hunlongyu"
            VALUE "FileDescription",  "Hopy Clipboard Manager"
            VALUE "FileVersion",      "@PROJECT_VERSION@"
            VALUE "InternalName",     "hopy"
            VALUE "LegalCopyright",   "© 2026 Hunlongyu · MIT License"
            VALUE "OriginalFilename", "hopy.exe"
            VALUE "ProductName",      "Hopy"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        // en-US (0x0409) + Unicode (1200); strings above are stored as UTF-16.
        VALUE "Translation", 0x0409, 1200
    END
END
